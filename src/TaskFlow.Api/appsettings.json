{
  "Database": {
    "ConnectionString": "Server=localhost,1433;Database=TaskFlowDb;User Id=sa;Password=Your_strong_password123;TrustServerCertificate=True;MultipleActiveResultSets=true",
    "ApplyMigrationsOnStartup": true,
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": false
  },
  "Jwt": {
    "Issuer": "TaskFlow",
    "Audience": "TaskFlowClients",
    "SecretKey": "TaskFlow_Development_Secret_Key_Change_In_Production_1234567890",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Seed": {
    "SeedSuperAdmin": false,
    "SeedSampleOrganization": false,
    "SuperAdminEmail": "superadmin@taskflow.local",
    "SuperAdminPassword": "SuperAdmin123!",
    "SuperAdminFirstName": "Super",
    "SuperAdminLastName": "Admin"
  },
  "FileStorage": {
    "ProfileImagesPath": "uploads/profiles",
    "ProfileImagesPublicPath": "/uploads/profiles",
    "MaxProfileImageSizeBytes": 5242880,
    "AttachmentsPath": "wwwroot/uploads",
    "MaxAttachmentSizeBytes": 26214400
  },
  "LoggingOptions": {
    "LogFilePath": "logs/taskflow-.log",
    "RollingInterval": "Day",
    "EnableRequestLogging": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
