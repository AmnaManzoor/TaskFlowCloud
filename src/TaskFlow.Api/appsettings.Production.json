{
  "Database": {
    "ApplyMigrationsOnStartup": false,
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": false
  },
  "Seed": {
    "SeedSuperAdmin": false,
    "SeedSampleOrganization": false
  },
  "LoggingOptions": {
    "EnableRequestLogging": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  }
}
